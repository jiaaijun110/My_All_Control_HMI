<UserControl
    x:Class="Controls.Vision.VisionDisplayControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border
        Background="#0F172A"
        BorderBrush="#334155"
        BorderThickness="1"
        CornerRadius="4">
        <Image
            x:Name="DisplayImage"
            Stretch="Uniform"
            RenderOptions.BitmapScalingMode="LowQuality" />
    </Border>
</UserControl>
