{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
        "Plc": {
            "type": "object",
            "properties": {
                "IpAddress": {
                    "type": "string",
                    "format": "ipv4",
                    "description": "PLC 的 IPv4 地址格式静态校验"
                },
                "Port": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 65535
                },
                "UseMock": {
                    "type": "boolean"
                },
                "HeartbeatDbNumber": {
                    "type": "integer",
                    "minimum": 0
                },
                "HeartbeatByteOffset": {
                    "type": "integer",
                    "minimum": 0
                },
                "HeartbeatValueByteSize": {
                    "type": "integer",
                    "enum": [2, 4]
                },
                "HeartbeatTimeoutMs": {
                    "type": "integer",
                    "minimum": 1
                },
                "ReconnectIntervalMs": {
                    "type": "integer",
                    "minimum": 1
                }
            },
            "required": [ "IpAddress", "UseMock" ]
        }
    }
}