<UserControl
    x:Class="AppMain.Views.RecipeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Border Margin="8" Padding="16" Background="{StaticResource SurfaceCard}" BorderBrush="{StaticResource BorderLine}" BorderThickness="1" CornerRadius="8">
            <StackPanel>
                <TextBlock Foreground="{StaticResource TextMain}" FontSize="16" FontWeight="SemiBold" Text="配方管理" />
                <TextBlock Margin="0,10,0,0" Foreground="{StaticResource TextDim}" Text="配方卡片容器（占位）" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
