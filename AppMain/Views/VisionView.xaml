<UserControl
    x:Class="AppMain.Views.VisionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cv="clr-namespace:Controls.Vision;assembly=Controls"
    Loaded="VisionView_OnLoaded"
    Unloaded="VisionView_OnUnloaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Margin="8"
            Padding="12"
            Background="{StaticResource SurfaceCard}"
            BorderBrush="{StaticResource BorderLine}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextMain}"
                    Text="工业视觉预览（GigE / WriteableBitmap 后端缓冲）" />
                <cv:VisionDisplayControl
                    x:Name="VisionDisplay"
                    Grid.Row="1"
                    Margin="0,10,0,0" />
            </Grid>
        </Border>

        <StackPanel Grid.Column="1" Margin="8">
            <Border
                Margin="0,0,0,10"
                Padding="14"
                Background="{StaticResource SurfaceCard}"
                BorderBrush="{StaticResource BorderLine}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel>
                    <TextBlock
                        FontSize="12"
                        Foreground="{StaticResource TextDim}"
                        Text="相机 IP" />
                    <TextBlock
                        Margin="0,2,0,8"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource AccentBlue}"
                        Text="192.168.0.2" />
                    <StackPanel Orientation="Horizontal">
                        <Ellipse
                            x:Name="CameraLinkLamp"
                            Width="10"
                            Height="10"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Fill="{StaticResource ErrorRed}" />
                        <TextBlock
                            x:Name="TxtCameraLink"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{StaticResource TextDim}"
                            Text="相机: 未连接" />
                    </StackPanel>
                    <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                        <Button
                            x:Name="BtnConnect"
                            Width="100"
                            Height="32"
                            Margin="0,0,8,0"
                            Click="BtnConnect_OnClick"
                            Content="连接相机"
                            Foreground="{StaticResource TextMain}" />
                        <Button
                            x:Name="BtnDisconnect"
                            Width="100"
                            Height="32"
                            Click="BtnDisconnect_OnClick"
                            Content="断开"
                            Foreground="{StaticResource TextDim}"
                            IsEnabled="False" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <Border
                Margin="0,0,0,10"
                Padding="16"
                Background="{StaticResource SurfaceCard}"
                BorderBrush="{StaticResource BorderLine}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Foreground="{StaticResource TextDim}" Text="OK" />
                        <TextBlock
                            x:Name="TxtOkCount"
                            FontSize="36"
                            FontWeight="Bold"
                            Foreground="{StaticResource SuccessGreen}"
                            Text="0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Foreground="{StaticResource TextDim}" Text="NG" />
                        <TextBlock
                            x:Name="TxtNgCount"
                            FontSize="36"
                            FontWeight="Bold"
                            Foreground="{StaticResource ErrorRed}"
                            Text="0" />
                    </StackPanel>
                    <TextBlock
                        x:Name="TxtTotalInspections"
                        Grid.ColumnSpan="2"
                        Margin="0,52,0,0"
                        FontSize="12"
                        Foreground="{StaticResource TextDim}"
                        Text="生产帧数: 0 | 亮度: —" />
                </Grid>
            </Border>
            <Border
                Padding="16"
                Background="{StaticResource SurfaceCard}"
                BorderBrush="{StaticResource BorderLine}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextMain}"
                        Text="虚拟信号灯" />
                    <Ellipse
                        x:Name="SignalLamp"
                        Width="120"
                        Height="120"
                        Margin="0,14,0,0"
                        Fill="{StaticResource SuccessGreen}"
                        Stroke="{StaticResource BorderLine}"
                        StrokeThickness="4" />
                    <TextBlock
                        x:Name="TxtLastResult"
                        Margin="0,8,0,0"
                        HorizontalAlignment="Center"
                        Foreground="{StaticResource TextDim}"
                        Text="当前结果: —" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
