<UserControl
    x:Class="AppMain.Views.DashboardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:AppMain.ValueConverters">
    <UserControl.Resources>
        <conv:OnlineOfflineTextConverter x:Key="OnlineOfflineTextConverter" />

        <conv:OnlineOfflineBrushConverter
            x:Key="OnlineOfflineEllipseFillConverter"
            TrueBrush="{StaticResource SuccessGreen}"
            FalseBrush="{StaticResource BorderLine}" />

        <conv:OnlineOfflineBrushConverter
            x:Key="OnlineOfflineTextForegroundConverter"
            TrueBrush="{StaticResource SuccessGreen}"
            FalseBrush="{StaticResource TextDim}" />
    </UserControl.Resources>
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 模块标题 -->
        <Border
            Grid.Row="0"
            Margin="0,0,0,10"
            Padding="14"
            Background="{DynamicResource SurfaceCard}"
            BorderBrush="{DynamicResource BorderLine}"
            BorderThickness="1"
            CornerRadius="8">
            <TextBlock
                Foreground="{DynamicResource AccentBlue}"
                FontSize="18"
                FontWeight="SemiBold"
                Text="📊 监控总览" />
        </Border>

        <!-- 监控内容：传感器卡片 + 2D 占位 -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 1号传感器 -->
            <Border
                Grid.Row="0"
                Grid.Column="0"
                Margin="0,0,8,0"
                Padding="16"
                Background="{DynamicResource SurfaceCard}"
                BorderBrush="{DynamicResource BorderLine}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Foreground="{DynamicResource AccentBlue}"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="1号传感器" />
                        <Ellipse
                            Width="8"
                            Height="8"
                            Margin="10,5,0,0"
                            Fill="{Binding IsConnected, Converter={StaticResource OnlineOfflineEllipseFillConverter}}" />
                        <TextBlock
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="11"
                            Text="{Binding IsConnected, Converter={StaticResource OnlineOfflineTextConverter}}"
                            Foreground="{Binding IsConnected, Converter={StaticResource OnlineOfflineTextForegroundConverter}}" />
                    </StackPanel>

                    <Separator Margin="0,12,0,10" Background="{DynamicResource BorderLine}" />

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Foreground="{DynamicResource TextDim}" Text="温度：" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Foreground="{DynamicResource TextMain}" Text="{Binding Sensor1TemperatureText}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Foreground="{DynamicResource TextDim}" Text="湿度：" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Foreground="{DynamicResource TextMain}" Text="{Binding Sensor1HumidityText}" />
                    </Grid>
                </StackPanel>
        </Border>

        <!-- 2号传感器 -->
            <Border
                Grid.Row="0"
                Grid.Column="1"
                Margin="8,0,0,0"
                Padding="16"
                Background="{DynamicResource SurfaceCard}"
                BorderBrush="{DynamicResource BorderLine}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            Foreground="{DynamicResource AccentBlue}"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="2号传感器" />
                        <Ellipse
                            Width="8"
                            Height="8"
                            Margin="10,5,0,0"
                            Fill="{Binding IsConnected, Converter={StaticResource OnlineOfflineEllipseFillConverter}}" />
                        <TextBlock
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="11"
                            Text="{Binding IsConnected, Converter={StaticResource OnlineOfflineTextConverter}}"
                            Foreground="{Binding IsConnected, Converter={StaticResource OnlineOfflineTextForegroundConverter}}" />
                    </StackPanel>

                    <Separator Margin="0,12,0,10" Background="{DynamicResource BorderLine}" />

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Foreground="{DynamicResource TextDim}" Text="温度：" />
                        <TextBlock Grid.Row="0" Grid.Column="1" Foreground="{DynamicResource TextMain}" Text="{Binding Sensor2TemperatureText}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Foreground="{DynamicResource TextDim}" Text="湿度：" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Foreground="{DynamicResource TextMain}" Text="{Binding Sensor2HumidityText}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 2D 产线线框图占位 -->
            <Border
                Grid.Row="1"
                Grid.ColumnSpan="2"
                Margin="0,10,0,0"
                Padding="16"
                Background="{DynamicResource SurfaceCard}"
                BorderBrush="{DynamicResource BorderLine}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid>
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource TextDim}"
                        FontSize="14"
                        Text="2D 产线线框图（占位）" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

