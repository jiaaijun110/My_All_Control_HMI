<Window
    x:Class="AppMain.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="ISA-101 高性能上位机"
    Width="1366"
    Height="768"
    Background="{DynamicResource BgDark}"
    WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="*" />
            <RowDefinition Height="42" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Row="0"
            Grid.ColumnSpan="2"
            Background="{DynamicResource SurfaceCard}"
            BorderBrush="{DynamicResource BorderLine}"
            BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="{StaticResource AccentBlue}"
                        Text="ALL CONTROL HMI" />
                    <TextBlock
                        Margin="14,0,0,1"
                        VerticalAlignment="Bottom"
                        Foreground="{StaticResource TextDim}"
                        Text="| ISA-101 高性能界面" />
                </StackPanel>

                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextMain}"
                    Text="智能控制系统" />

                <StackPanel
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        Margin="0,0,14,0"
                        FontSize="12"
                        Foreground="{StaticResource TextMain}"
                        Text="{Binding CurrentUserName}" />

                    <Button
                        Width="140"
                        Height="34"
                        Margin="0,0,10,0"
                        Padding="12,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{StaticResource AccentBlue}"
                        Content="切换用户"
                        Click="SwitchUser_Click" />

                    <Button
                        Width="120"
                        Height="34"
                        Padding="12,0"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{StaticResource TextDim}"
                        Content="退出登录"
                        Click="Logout_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            Grid.Column="0"
            Background="{DynamicResource SurfaceCard}"
            BorderBrush="{DynamicResource BorderLine}"
            BorderThickness="0,0,1,0">
            <StackPanel Margin="0,15">
                <Button
                    Height="50"
                    Padding="20,0"
                    HorizontalContentAlignment="Left"
                    Click="Nav_Click"
                    Content="🏠 监控总览"
                    Foreground="{StaticResource AccentBlue}"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                    Tag="Dashboard" />
                <Button
                    Height="50"
                    Padding="20,0"
                    HorizontalContentAlignment="Left"
                    Click="Nav_Click"
                    Content="⚙ 手动调试"
                    Foreground="{StaticResource TextDim}"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                    Tag="Motor" />
                <Button
                    Height="50"
                    Padding="20,0"
                    HorizontalContentAlignment="Left"
                    Click="Nav_Click"
                    Content="📷 视觉监控"
                    Foreground="{StaticResource TextDim}"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                    Tag="Vision" />
                <Button
                    Height="50"
                    Padding="20,0"
                    HorizontalContentAlignment="Left"
                    Click="Nav_Click"
                    Content="📋 配方管理"
                    Foreground="{StaticResource TextDim}"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                    Tag="Recipe" />
                <Button
                    Height="50"
                    Padding="20,0"
                    HorizontalContentAlignment="Left"
                    Click="Nav_Click"
                    Content="🚨 报警历史"
                    Foreground="{StaticResource TextDim}"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                    Tag="Alarm" />
                <Button
                    Height="50"
                    Padding="20,0"
                    HorizontalContentAlignment="Left"
                    Click="Nav_Click"
                    Content="🔧 系统设置"
                    Foreground="{StaticResource TextDim}"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                    Tag="Settings" />
                <Button
                    Height="50"
                    Padding="20,0"
                    HorizontalContentAlignment="Left"
                    Click="Nav_Click"
                    Content="📜 系统日志"
                    Foreground="{StaticResource TextDim}"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                    Tag="Log" />
            </StackPanel>
        </Border>

        <ContentControl
            x:Name="MainPageContainer"
            Grid.Row="1"
            Grid.Column="1"
            Margin="15" />

        <Border
            Grid.Row="2"
            Grid.ColumnSpan="2"
            Background="{DynamicResource BgDark}"
            BorderBrush="{DynamicResource BorderLine}"
            BorderThickness="0,1,0,0">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
                    <Ellipse
                        x:Name="PlcStatusLamp"
                        Width="8"
                        Height="8"
                        Margin="0,0,5,0"
                        Fill="{Binding PlcStatusLampBrush}" />
                    <TextBlock
                        FontSize="11"
                        Foreground="{StaticResource TextDim}"
                        Text="{Binding PlcStatusText}" />
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                    <Ellipse
                        Width="8"
                        Height="8"
                        Margin="0,0,5,0"
                        Fill="{Binding DatabaseLampBrush}" />
                    <TextBlock
                        FontSize="11"
                        Foreground="{StaticResource TextDim}"
                        Text="{Binding DatabaseStatusText}" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock
                        FontSize="11"
                        Foreground="{StaticResource TextDim}"
                        Text="{Binding CurrentUserName}" />
                    <TextBlock
                        Margin="10,0,0,0"
                        FontSize="11"
                        Foreground="{Binding CurrentUserRoleBrush}"
                        Text="{Binding CurrentUserRoleText}" />
                </StackPanel>
                <Border
                    Grid.Column="3"
                    Margin="8,4"
                    Padding="8,2"
                    VerticalAlignment="Center"
                    Background="{DynamicResource BgDark}"
                    BorderBrush="{DynamicResource BorderLine}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <TextBlock
                        FontSize="10"
                        Foreground="{StaticResource TextDim}"
                        Text="{Binding LastInfoTickerText}"
                        TextTrimming="CharacterEllipsis"
                        ToolTip="{Binding LastInfoTickerText}" />
                </Border>
                <TextBlock
                    Grid.Column="4"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    FontSize="11"
                    Foreground="{StaticResource TextDim}"
                    Text="{Binding ResourceUsageText}" />
            </Grid>
        </Border>
    </Grid>
</Window>