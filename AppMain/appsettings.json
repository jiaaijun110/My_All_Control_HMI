{
    "$schema": "./appsettings.schema.json",
    "Plc": {
        "IpAddress": "192.168.0.1",
        "IpAddress_Note": "西门子 S7-1200 的实际 IP，修改后需重启程序",

        "Port": 102,
        "Port_Note": "西门子默认端口 102，ModbusTCP 通常是 502",

        "ConnectTimeout": 3000,
        "ConnectTimeout_Note": "超时时间",

        "RetryCount": 3,
        "RetryCount_Note": "重试次数",

        "UseMock": true,

        "HeartbeatDbNumber": 7,
        "HeartbeatByteOffset": 0,
        "HeartbeatValueByteSize": 4,
        "HeartbeatTimeoutMs": 5000,
        "ReconnectIntervalMs": 5000
    },
    "Database": {
        "ConnectionString": "DataSource=Data/ProductionData.db",
        "ConnectionString_Note": "SQLite文件路径。建议放在程序根目录的 Data 文件夹下，方便备份",

        "IsAutoCreateDb": true,
        "IsAutoCreateDb_Note": "程序启动时，如果发现没数据库文件，是否自动创建它？工业现场建议开启",

        "DbBackupPath": "Default",
        "DbBackupPath_Note": "写 Default 表示自动识别：有 D 盘用 D 盘，没 D 盘用程序所在目录"
    },
    "Serilog": {
        "Using": [ "Serilog.Sinks.File", "Serilog.Sinks.Async" ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "System": "Warning"
            }

        },
        "WriteTo": [
            {
                "Name": "Async",
                "Name_Note": "异步写入：极其重要！防止写日志卡住 PLC 采集循环，工业实时性必备",
                "Args": {
                    "configure": [
                        {
                            "Name": "File",
                            "Args": {
                                "path": "Logs/log.txt",
                                "rollingInterval": "Day",
                                "rollingInterval_Note": "每天生成一个新文件，方便按日期追溯事故",
                                "retainedFileCountLimit": 30,
                                "retainedFileCountLimit_Note": "只保留最近 30 天日志，防止工控机 C 盘写满导致系统崩溃",
                                "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] [ThreadId:{ThreadId}] {Message:lj}{NewLine}{Exception}"
                            }
                        }
                    ]
                }
            }
        ]
    }
}